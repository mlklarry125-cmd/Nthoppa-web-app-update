# Runtime database connection (use the Supabase pooled connection string in production)
DATABASE_URL="postgresql://username:password@host:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct database connection for migrations and Prisma operations
DIRECT_URL="postgresql://username:password@host:5432/postgres"

# Authentication secrets — use strong random values of at least 32 characters
JWT_SECRET="replace-with-a-secure-random-secret"
NEXTAUTH_SECRET="replace-with-a-secure-random-secret"

# Set this to the final deployment URL on each platform
NEXTAUTH_URL="http://localhost:3000"

# Supabase project configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-your-service-role-key"

NODE_ENV="development"
